# Server Configuration
PORT=3001
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=20             # max 20 requests per window

# File Management
MAX_FILE_SIZE_MB=500          # max downloadable file size in MB
TEMP_DIR=./temp               # temporary download directory
FILE_TTL_MS=300000            # files deleted after 5 minutes

# CORS
FRONTEND_URL=http://localhost:5173
